<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title>{{ title }} — Cooking Nimble</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍳</text></svg>">
    <link rel="stylesheet" href="{{ '/reset.css' |> url }}">
    <link rel="stylesheet" href="{{ '/tokens.css' |> url }}">
    <link rel="stylesheet" href="{{ '/styles.css' |> url }}">
  </head>
  <body>
    <header>
      <nav>
        <a href="{{ '/' |> url }}" class="site-title"><span class="site-title-gradient">Cooking</span> Nimble</a>
      </nav>
    </header>
    <main>
      <article>
        <h1>{{ title }}</h1>
        {{ content }}
      </article>
    </main>
    <footer>
      <a href="{{ '/' |> url }}">← Retour à l'index</a>
    </footer>
  </body>
</html>
